    </Container>
    <Link
      id="link1"
      disabled="{{user_logout.isFetching}}"
      horizontalAlign="center"
      iconBefore="line/interface-login"
      marginType="normal"
      showUnderline="never"
      style={{
        ordered: [
          { text: "rgba(2, 6, 12, 0.75)" },
          { fontSize: "h6Font" },
          { fontWeight: "700" },
          { lineHeight: "1.43em" },
        ],
      }}
      text="Logout"
      textSize="h6"
    >
      <Event
        event="click"
        method="trigger"
        params={{ ordered: [] }}
        pluginId="user_logout"
        type="datasource"
        waitMs="300"
        waitType="debounce"
      />
    </Link>
  </Body>
  <Footer>
    <Avatar
      id="avatar1"
      fallback="{{ current_user.fullName }}"
      imageSize={32}
      label="{{ current_user.fullName }}"
      labelCaption="{{ current_user.email }}"
      margin="4px 4px"
      src="{{ current_user.profilePhotoUrl }}"
      style={{ map: { background: "automatic" } }}
    />
  </Footer>
</SidebarFrame>
