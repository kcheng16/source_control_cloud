            highlight="{{ tabbedContainer1.currentViewIndex === 0 || tabbedContainer1.currentViewIndex === 1 }}"
            icon="line/interface-setting-menu-parallel-hamburger-square"
            iconPosition="left"
            itemType="custom"
            key="649a5"
            label="Billing"
          >
            <Event
              enabled="{{ tabbedContainer1.currentViewIndex > 1 }}"
              event="click"
              method="run"
              params={{
                ordered: [
                  {
                    src: '// DP event\nwindow.send_dp_event({\n  event: "click",\n  object_name: "billing-sidebar",\n  object_value: {}\n});\n\ntabbedContainer1.setCurrentViewIndex(0);\ntabbedContainer2.setCurrentViewIndex(0);\nauto_suggestions.setValue(null);\ntextInput1.resetValue();\nreset_search_data.trigger();\nGetCart.trigger();\n',
                  },
                ],
              }}
              pluginId=""
              type="script"
              waitMs="300"
              waitType="debounce"
            />
