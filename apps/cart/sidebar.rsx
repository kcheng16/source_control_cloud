    >
      <Event
        event="click"
        method="setCurrentViewIndex"
        params={{
          ordered: [
            { viewIndex: "{{(rootContainer.currentViewIndex + 1) %2}}" },
          ],
        }}
        pluginId="rootContainer"
        type="widget"
        waitMs="0"
        waitType="debounce"
      />
